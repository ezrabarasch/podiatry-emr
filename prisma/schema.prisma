// ─────────────────────────────────────────────────────────────────────────────
// Podiatry EMR — Prisma Schema
// Stack: Next.js + PostgreSQL + Prisma + Docker on DigitalOcean
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum FacilityType {
  SNF
  ALF
}

enum VisitType {
  new_patient
  established
}

enum VisitStatus {
  draft
  signed
}

enum CareflowType {
  at_risk_podiatry
  wound_care
  // planned: cardiology, physiatry, ot_pt_sp, nutrition, psych, primary_care
  // additional careflow types added here as we build them
}

enum PlaceOfService {
  bedside
  wheelchair
}

enum DataSource {
  manual
  pcc_import
}

// ─────────────────────────────────────────────────────────────────────────────
// FACILITIES
// ─────────────────────────────────────────────────────────────────────────────

model Facility {
  id            String       @id @default(uuid())
  name          String
  facilityType  FacilityType
  address       String?
  npi           String?
  pccFacilityId String?      // PCC's internal facility ID for linking
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  patients      Patient[]

  @@map("facilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROVIDERS
// ─────────────────────────────────────────────────────────────────────────────

model Provider {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  credentials String?  // e.g. DPM
  npi         String?
  email       String   @unique
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visits      Visit[]
  accounts    Account[]

  @@map("providers")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH — NextAuth
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  providerId        String
  type              String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  provider          Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([type, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  providerId   String
  expires      DateTime

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENTS
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id           String       @id @default(uuid())
  facilityId   String
  pccPatientId String?      @unique // PCC's internal patient ID — links to PCC DB
  firstName    String
  lastName     String
  dob          DateTime
  facilityType FacilityType // copied from facility, denormalized for visit snapshot
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  facility     Facility     @relation(fields: [facilityId], references: [id])
  visits       Visit[]
  diagnoses    PatientDiagnosis[]
  medications  PatientMedication[]

  @@map("patients")
}

// ─────────────────────────────────────────────────────────────────────────────
// VISITS
// ─────────────────────────────────────────────────────────────────────────────

model Visit {
  id             String         @id @default(uuid())
  patientId      String
  providerId     String
  visitDate      DateTime
  visitType      VisitType
  facilityType   FacilityType   // snapshotted from patient at time of visit creation
  placeOfService PlaceOfService?
  careflowType   CareflowType   @default(at_risk_podiatry)
  status         VisitStatus    @default(draft)
  signedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  patient        Patient        @relation(fields: [patientId], references: [id])
  provider       Provider       @relation(fields: [providerId], references: [id])

  emrImport      VisitEmrImport?
  fieldSelections VisitFieldSelection[]
  note           VisitNote?
  diagnosisAssertions  PatientDiagnosisAssertion[]
  medicationAssertions PatientMedicationAssertion[]

  @@map("visits")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMR IMPORT — PCC data pulled at visit open time
// ─────────────────────────────────────────────────────────────────────────────

model VisitEmrImport {
  id             String   @id @default(uuid())
  visitId        String   @unique
  pccPatientId   String?
  vitals         Json     // { bp_status: "elevated_with_htn", ... }
  medications    Json     // [{ name, dosage, frequency }, ...]
  medicalHistory Json     // [{ icd10: "E11.9", description: "Type 2 Diabetes" }, ...]
  pulledAt       DateTime @default(now())
  rawResponse    Json?    // full source data for debugging

  visit          Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("visit_emr_imports")
}

// ─────────────────────────────────────────────────────────────────────────────
// FIELD SELECTIONS — raw checkbox/radio captures (source of truth for logic engine)
// ─────────────────────────────────────────────────────────────────────────────

model VisitFieldSelection {
  id        String   @id @default(uuid())
  visitId   String
  section   String   // e.g. "vascular_exam"
  fieldKey  String   // e.g. "dp_pulse_right"
  value     String   // e.g. "absent"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@unique([visitId, section, fieldKey]) // one value per field per visit
  @@map("visit_field_selections")
}

// ─────────────────────────────────────────────────────────────────────────────
// VISIT NOTE — immutable snapshot created at sign-off
// ─────────────────────────────────────────────────────────────────────────────

model VisitNote {
  id                   String   @id @default(uuid())
  visitId              String   @unique
  noteText             String   @db.Text  // fully assembled progress note
  procedureNotes       Json?    // [{ label: "Procedure Note", text: "..." }, ...]
  specialSections      Json?    // [{ label: "Smoking Cessation Counseling", text: "..." }, ...]
  diagnoses            Json     // [{ icd10: "B35.1", description: "Tinea unguium" }, ...]
  cptCodes             Json     // [{ code: "11721", description: "...", qualifier: "class_b" }, ...]
  addendum             String?  @db.Text  // free-text addendum added before sign
  vitalsSnapshot       Json?    // BP status at time of visit
  medicationsSnapshot  Json?    // med list at time of sign
  medicalHistorySnapshot Json?  // dx list at time of sign
  billingAlerts        Json?    // [{ code: "11720", message: "Missing class B/C qualifier" }]
  snapshotAt           DateTime @default(now())

  visit                Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("visit_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREFLOW RULES — the logic engine (conditional rules)
// ─────────────────────────────────────────────────────────────────────────────

model CareflowRule {
  id                  String       @id @default(uuid())
  careflowType        CareflowType @default(at_risk_podiatry)
  section             String       // e.g. "vascular_exam"
  fieldKey            String       // e.g. "dp_pulse_right"
  fieldValue          String       // e.g. "absent"
  noteFragment        String?      @db.Text
  icd10Codes          Json?        // ["I73.9"]
  cptCodes            Json?        // ["11720"]
  cptQualifier        String?      // "class_a" | "class_b" | "class_c"
  dxCondition         String?      // named condition e.g. "patient_is_diabetic"
  sectionLabel        String?      // e.g. "Procedure Note", "Smoking Cessation Counseling"
  procedureNarrative  String?      @db.Text
  priority            Int          @default(0)
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([careflowType, section, fieldKey, fieldValue])
  @@map("careflow_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// STATIC FRAGMENTS — always-present text regardless of field selections
// ─────────────────────────────────────────────────────────────────────────────

model CareflowStaticFragment {
  id           String       @id @default(uuid())
  careflowType CareflowType @default(at_risk_podiatry)
  section      String
  position     Int
  fragmentText String       @db.Text
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("careflow_static_fragments")
}

// ─────────────────────────────────────────────────────────────────────────────
// DERIVED RULES — fire based on generated DX codes, not field selections
// ─────────────────────────────────────────────────────────────────────────────

model CareflowDerivedRule {
  id             String       @id @default(uuid())
  careflowType   CareflowType @default(at_risk_podiatry)
  conditionName  String       // e.g. "pvd_dx_present"
  triggerCodes   Json         // ["I73.9", "I70.21"]
  noteFragment   String       @db.Text
  outputSection  String       // e.g. "Assessment & Plan"
  priority       Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("careflow_derived_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// CPT QUALIFIER RULES — defines billing requirements per CPT
// ─────────────────────────────────────────────────────────────────────────────

model CptQualifierRule {
  id               String   @id @default(uuid())
  cptCode          String   @unique
  description      String
  requiresQualifier Boolean @default(false)
  minimumClass     String?  // "class_b or class_c"
  notes            String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cpt_qualifier_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT-LEVEL DIAGNOSES — global, cross-service-line visibility.
//
// Populated only when a visit is SIGNED (not on draft saves), per product
// decision: diagnoses become part of the shared chart at encounter sign-off,
// not while a provider is still charting. One row per (patient, icd10) —
// "no duplicates" means the same diagnosis code is never represented twice
// for a patient, regardless of how many visits or service lines assert it.
// Re-assertion by a later visit updates lastConfirmedAt/lastConfirmedBy
// rather than creating a second row. Full history of which visit asserted
// it when lives in PatientDiagnosisAssertion below, so nothing is lost.
// ─────────────────────────────────────────────────────────────────────────────

model PatientDiagnosis {
  id                String       @id @default(uuid())
  patientId         String
  icd10             String
  description       String
  firstAssertedAt   DateTime     @default(now())
  lastConfirmedAt   DateTime     @default(now())
  lastConfirmedById String       // visitId of the most recent signed visit that asserted it
  active            Boolean      @default(true) // set false if clinically resolved/retired

  patient           Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assertions        PatientDiagnosisAssertion[]

  @@unique([patientId, icd10])
  @@map("patient_diagnoses")
}

// Append-only provenance log — every signed visit that asserted a diagnosis,
// even if PatientDiagnosis already existed (so "who said this, and when,
// across which service lines" is always answerable).
model PatientDiagnosisAssertion {
  id                 String           @id @default(uuid())
  patientDiagnosisId String
  visitId            String
  careflowType       CareflowType     // which service line asserted it
  assertedAt         DateTime         @default(now())

  patientDiagnosis   PatientDiagnosis @relation(fields: [patientDiagnosisId], references: [id], onDelete: Cascade)
  visit              Visit            @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@unique([patientDiagnosisId, visitId])
  @@map("patient_diagnosis_assertions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT-LEVEL MEDICATIONS — same pattern as diagnoses: global visibility,
// populated on sign, one row per (patient, name+dosage+frequency) to avoid
// duplicates, with provenance preserved separately.
// ─────────────────────────────────────────────────────────────────────────────

model PatientMedication {
  id                String       @id @default(uuid())
  patientId         String
  name              String
  dosage            String?
  frequency         String?
  firstAssertedAt   DateTime     @default(now())
  lastConfirmedAt   DateTime     @default(now())
  lastConfirmedById String       // visitId of the most recent signed visit that asserted it
  active            Boolean      @default(true) // set false if discontinued

  patient           Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assertions        PatientMedicationAssertion[]

  @@unique([patientId, name, dosage, frequency])
  @@map("patient_medications")
}

model PatientMedicationAssertion {
  id                  String            @id @default(uuid())
  patientMedicationId String
  visitId             String
  careflowType        CareflowType
  assertedAt          DateTime          @default(now())

  patientMedication   PatientMedication @relation(fields: [patientMedicationId], references: [id], onDelete: Cascade)
  visit               Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@unique([patientMedicationId, visitId])
  @@map("patient_medication_assertions")
}

enum CodeSystem {
  icd10
  cpt
}

model Code {
  id          String     @id @default(uuid())
  system      CodeSystem
  code        String
  description String

  @@unique([system, code])
  @@map("codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREFLOW FORM DEFINITION — drives the SectionCard/FieldRow renderer.
// Mirrors the shape of the existing SECTIONS literal in app/visits/[id]/page.tsx
// so the renderer needs no changes, only its data source does.
//
// `type` is a string, not an enum — across wound care, cardiology, physiatry,
// OT/PT/SP, nutrition, psych, and primary care, the set of input types needed
// (numeric measurement, free text, multi-select, body diagrams, etc.) is not
// fully known yet and will keep growing. A closed enum would mean a schema
// migration every time a new service line needs a new input shape. Instead,
// `type` is looked up against a renderer registry in the app (see
// lib/careflow/field-types.ts), and `config` holds whatever shape that
// renderer needs (options for radio/multiselect, unit/min/max for numeric,
// regions for a body diagram, etc.) so adding an input type is a new
// registry entry, not a migration.
// ─────────────────────────────────────────────────────────────────────────────

model CareflowSection {
  id           String       @id @default(uuid())
  careflowType CareflowType @default(at_risk_podiatry)
  sectionId    String       // e.g. "vascular_exam" — matches CareflowRule.section
  label        String       // e.g. "Vascular Exam"
  position     Int          @default(0)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  groups       CareflowFieldGroup[]

  @@unique([careflowType, sectionId])
  @@map("careflow_sections")
}

model CareflowFieldGroup {
  id          String          @id @default(uuid())
  sectionId   String
  groupLabel  String?
  accentColor String?
  position    Int             @default(0)

  section     CareflowSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  fields      CareflowField[]

  @@map("careflow_field_groups")
}

model CareflowField {
  id         String             @id @default(uuid())
  groupId    String
  type       String             // looked up in the field-type renderer registry, e.g. "radio", "checkbox", "numeric", "free_text", "multi_select", "body_diagram"
  fieldKey   String             // e.g. "dp_pulse_right" — matches CareflowRule.fieldKey
  label      String
  config     Json?              // shape depends on `type` — see lib/careflow/field-types.ts for each type's expected config
  position   Int                @default(0)

  group      CareflowFieldGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("careflow_fields")
}

// ─────────────────────────────────────────────────────────────────────────────
// Podiatry EMR — Prisma Schema
// Stack: Next.js + PostgreSQL + Prisma + Docker on DigitalOcean
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum FacilityType {
  SNF
  ALF
}

enum VisitType {
  new_patient
  established
}

enum VisitStatus {
  draft
  signed
}

enum CareflowType {
  at_risk_podiatry
  // additional careflow types added here as we build them
}

enum PlaceOfService {
  bedside
  wheelchair
}

enum DataSource {
  manual
  pcc_import
}

enum PayerType {
  MEDICARE
  MEDICAID
  COMMERCIAL
  OTHER
}

enum Role {
  PROVIDER
  OFFICE
  ADMIN
}

enum SessionAction {
  LOGIN
  LOGOUT
  FAILED
  LOCKED
}

// ─────────────────────────────────────────────────────────────────────────────
// FACILITIES
// ─────────────────────────────────────────────────────────────────────────────

model Facility {
  id            String       @id @default(uuid())
  name          String
  facilityType  FacilityType
  address       String?
  npi           String?
  posCode       String?      // Place of Service code (e.g. "31" SNF, "13" ALF)
  pccFacilityId String?      // PCC's internal facility ID for linking
  adminContactName  String?
  adminContactPhone String?
  adminContactEmail String?
  donContactName    String?
  donContactPhone   String?
  donContactEmail   String?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  patients      Patient[]

  @@map("facilities")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS — providers, office staff, and admins
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  username            String    @unique // used for login
  email               String?   // optional, NOT unique
  firstName           String
  lastName            String
  credentials         String?   // e.g. DPM — providers only
  role                Role
  password            String    // bcrypt hashed
  failedLoginAttempts Int       @default(0)
  lockedAt            DateTime?
  lastLoginAt         DateTime?
  currentSessionToken String?   // single-device enforcement
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  visits              Visit[]
  sessionLogs         SessionLog[]
  patientUploads      PatientUpload[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION LOGS — audit trail of login/logout/failed/locked events
// ─────────────────────────────────────────────────────────────────────────────

model SessionLog {
  id        String        @id @default(uuid())
  userId    String?       // nullable: FAILED attempts for unknown usernames
  username  String
  ipAddress String?
  userAgent String?
  action    SessionAction
  createdAt DateTime      @default(now())

  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([username])
  @@index([action])
  @@map("session_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENTS
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id           String       @id @default(uuid())
  facilityId   String
  pccPatientId String?      @unique // PCC's internal patient ID — links to PCC DB
  firstName    String
  lastName     String
  dob          DateTime
  facilityType FacilityType // copied from facility, denormalized for visit snapshot
  roomNumber      String?
  admissionDate   DateTime?
  dischargeDate   DateTime?
  medicareNumber  String?
  medicaidNumber  String?
  primaryLanguage String?
  gender          String?
  maritalStatus   String?
  medicalRecordNumber String?
  isDeceased      Boolean   @default(false)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  facility     Facility     @relation(fields: [facilityId], references: [id])
  visits       Visit[]
  coverages    PatientCoverage[]
  diagnoses    PatientDiagnosis[]
  uploads      PatientUpload[]
  medications       PatientMedication[]
  allergies         PatientAllergy[]
  observations      PatientObservation[]
  contacts          PatientContact[]
  adtRecords        PatientAdtRecord[]
  practitioners     PatientPractitioner[]
  immunizations     PatientImmunization[]
  diagnosticReports PatientDiagnosticReport[]
  carePlans         PatientCarePlan[]
  assessments       PatientAssessment[]
  episodesOfCare    PatientEpisodeOfCare[]
  therapyTracks     PatientTherapyTrack[]

  @@map("patients")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT DIAGNOSES — active problem list (synced from PCC)
// ─────────────────────────────────────────────────────────────────────────────

model PatientDiagnosis {
  id          String   @id @default(uuid())
  patientId   String
  icd10       String
  description String
  active      Boolean  @default(true)
  syncedAt    DateTime @default(now())

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_diagnoses")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT UPLOADS — documents attached to a patient, stored on local disk
// ─────────────────────────────────────────────────────────────────────────────

model PatientUpload {
  id            String   @id @default(uuid())
  patientId     String
  uploadedById  String
  fileName      String   // original filename
  fileLabel     String?  // user-given display name
  mimeType      String
  fileSizeBytes Int
  storageKey    String   // path on disk relative to the uploads root
  createdAt     DateTime @default(now())

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])

  @@index([patientId])
  @@map("patient_uploads")
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT COVERAGE — payer / insurance info (synced from PCC)
// ─────────────────────────────────────────────────────────────────────────────

model PatientCoverage {
  id              String    @id @default(uuid())
  patientId       String
  payerName       String
  payerType       PayerType
  memberId        String?
  groupId         String?
  effectiveDate   DateTime?
  terminationDate DateTime?
  isPrimary       Boolean   @default(false)
  active          Boolean   @default(true)
  syncedAt        DateTime  @default(now())

  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_coverages")
}

// ─────────────────────────────────────────────────────────────────────────────
// VISITS
// ─────────────────────────────────────────────────────────────────────────────

model Visit {
  id             String         @id @default(uuid())
  patientId      String
  providerId     String
  visitDate      DateTime
  visitType      VisitType
  facilityType   FacilityType   // snapshotted from patient at time of visit creation
  placeOfService PlaceOfService?
  careflowType   CareflowType   @default(at_risk_podiatry)
  status         VisitStatus    @default(draft)
  signedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  patient        Patient        @relation(fields: [patientId], references: [id])
  provider       User           @relation(fields: [providerId], references: [id])

  emrImport      VisitEmrImport?
  fieldSelections VisitFieldSelection[]
  note           VisitNote?

  @@map("visits")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMR IMPORT — PCC data pulled at visit open time
// ─────────────────────────────────────────────────────────────────────────────

model VisitEmrImport {
  id             String   @id @default(uuid())
  visitId        String   @unique
  pccPatientId   String?
  vitals         Json     // { bp_status: "elevated_with_htn", ... }
  medications    Json     // [{ name, dosage, frequency }, ...]
  medicalHistory Json     // [{ icd10: "E11.9", description: "Type 2 Diabetes" }, ...]
  pulledAt       DateTime @default(now())
  rawResponse    Json?    // full source data for debugging

  visit          Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("visit_emr_imports")
}

// ─────────────────────────────────────────────────────────────────────────────
// FIELD SELECTIONS — raw checkbox/radio captures (source of truth for logic engine)
// ─────────────────────────────────────────────────────────────────────────────

model VisitFieldSelection {
  id        String   @id @default(uuid())
  visitId   String
  section   String   // e.g. "vascular_exam"
  fieldKey  String   // e.g. "dp_pulse_right"
  value     String   // e.g. "absent"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visit     Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@unique([visitId, section, fieldKey]) // one value per field per visit
  @@map("visit_field_selections")
}

// ─────────────────────────────────────────────────────────────────────────────
// VISIT NOTE — immutable snapshot created at sign-off
// ─────────────────────────────────────────────────────────────────────────────

model VisitNote {
  id                   String   @id @default(uuid())
  visitId              String   @unique
  noteText             String   @db.Text  // fully assembled progress note
  procedureNotes       Json?    // [{ label: "Procedure Note", text: "..." }, ...]
  specialSections      Json?    // [{ label: "Smoking Cessation Counseling", text: "..." }, ...]
  diagnoses            Json     // [{ icd10: "B35.1", description: "Tinea unguium" }, ...]
  cptCodes             Json     // [{ code: "11721", description: "...", qualifier: "class_b" }, ...]
  addendum             String?  @db.Text  // free-text addendum added before sign
  vitalsSnapshot       Json?    // BP status at time of visit
  medicationsSnapshot  Json?    // med list at time of sign
  medicalHistorySnapshot Json?  // dx list at time of sign
  billingAlerts        Json?    // [{ code: "11720", message: "Missing class B/C qualifier" }]
  snapshotAt           DateTime @default(now())

  visit                Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("visit_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREFLOW RULES — the logic engine (conditional rules)
// ─────────────────────────────────────────────────────────────────────────────

model CareflowRule {
  id                  String       @id @default(uuid())
  careflowType        CareflowType @default(at_risk_podiatry)
  section             String       // e.g. "vascular_exam"
  fieldKey            String       // e.g. "dp_pulse_right"
  fieldValue          String       // e.g. "absent"
  noteFragment        String?      @db.Text
  icd10Codes          Json?        // ["I73.9"]
  cptCodes            Json?        // ["11720"]
  cptQualifier        String?      // "class_a" | "class_b" | "class_c"
  dxCondition         String?      // named condition e.g. "patient_is_diabetic"
  sectionLabel        String?      // e.g. "Procedure Note", "Smoking Cessation Counseling"
  procedureNarrative  String?      @db.Text
  priority            Int          @default(0)
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@unique([careflowType, section, fieldKey, fieldValue])
  @@map("careflow_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// STATIC FRAGMENTS — always-present text regardless of field selections
// ─────────────────────────────────────────────────────────────────────────────

model CareflowStaticFragment {
  id           String       @id @default(uuid())
  careflowType CareflowType @default(at_risk_podiatry)
  section      String
  position     Int
  fragmentText String       @db.Text
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("careflow_static_fragments")
}

// ─────────────────────────────────────────────────────────────────────────────
// DERIVED RULES — fire based on generated DX codes, not field selections
// ─────────────────────────────────────────────────────────────────────────────

model CareflowDerivedRule {
  id             String       @id @default(uuid())
  careflowType   CareflowType @default(at_risk_podiatry)
  conditionName  String       // e.g. "pvd_dx_present"
  triggerCodes   Json         // ["I73.9", "I70.21"]
  noteFragment   String       @db.Text
  outputSection  String       // e.g. "Assessment & Plan"
  priority       Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("careflow_derived_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// CPT QUALIFIER RULES — defines billing requirements per CPT
// ─────────────────────────────────────────────────────────────────────────────

model CptQualifierRule {
  id               String   @id @default(uuid())
  cptCode          String   @unique
  description      String
  requiresQualifier Boolean @default(false)
  minimumClass     String?  // "class_b or class_c"
  notes            String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cpt_qualifier_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// PCC ETL EXPANSION — additional PCC resources synced per patient (v1.4)
// ─────────────────────────────────────────────────────────────────────────────

model PatientMedication {
  id          String    @id @default(uuid())
  patientId   String
  pccOrderId  String?
  description String
  status      String?
  startDate   DateTime?
  endDate     DateTime?
  directions  String?
  strength    String?
  strengthUOM String?
  rxNormId    String?
  generic     Boolean   @default(false)
  narcotic    Boolean   @default(false)
  orderDate   DateTime?
  syncedAt    DateTime  @default(now())

  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccOrderId])
  @@map("patient_medications")
}

model PatientAllergy {
  id             String    @id @default(uuid())
  patientId      String
  pccAllergyId   String?
  allergen       String
  allergenCode   String?
  category       String?
  type           String?
  severity       String?
  reaction       String?
  reactionNote   String?
  clinicalStatus String?
  onsetDate      DateTime?
  resolvedDate   DateTime?
  syncedAt       DateTime  @default(now())

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, allergen])
  @@map("patient_allergies")
}

model PatientObservation {
  id               String    @id @default(uuid())
  patientId        String
  pccObservationId String?
  type             String    // BP, WEIGHT, TEMP, O2_SAT, HEART_RATE, BLOOD_SUGAR, PAIN, RESPIRATIONS, HEIGHT
  value            Float?
  diastolicValue   Float?
  systolicValue    Float?
  unit             String?
  method           String?
  recordedDate     DateTime
  recordedBy       String?
  syncedAt         DateTime  @default(now())

  patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_observations")
}

model PatientContact {
  id           String   @id @default(uuid())
  patientId    String
  pccContactId String?
  firstName    String?
  lastName     String?
  relationship String?
  contactType  String?
  homePhone    String?
  cellPhone    String?
  officePhone  String?
  email        String?
  addressLine1 String?
  city         String?
  state        String?
  postalCode   String?
  isGuarantor  Boolean  @default(false)
  syncedAt     DateTime @default(now())

  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccContactId])
  @@map("patient_contacts")
}

model PatientAdtRecord {
  id                String    @id @default(uuid())
  patientId         String
  pccAdtRecordId    String?
  actionCode        String?
  actionType        String?
  effectiveDateTime DateTime?
  roomDesc          String?
  bedDesc           String?
  unitDesc          String?
  floorDesc         String?
  payerName         String?
  payerType         String?
  transferReason    String?
  dischargeStatus   String?
  syncedAt          DateTime  @default(now())

  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccAdtRecordId])
  @@map("patient_adt_records")
}

model PatientPractitioner {
  id                String   @id @default(uuid())
  patientId         String
  pccPractitionerId String?
  firstName         String?
  lastName          String?
  npi               String?
  providerType      String?
  relation          String?
  title             String?
  taxonomyCode      String?
  syncedAt          DateTime @default(now())

  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccPractitionerId])
  @@map("patient_practitioners")
}

model PatientImmunization {
  id                     String    @id @default(uuid())
  patientId              String
  pccImmunizationId      String?
  immunization           String?
  cvxCode                String?
  administrationDateTime DateTime?
  administeredBy         String?
  lotNumber              String?
  manufacturerName       String?
  consentStatus          String?
  given                  Boolean   @default(false)
  syncedAt               DateTime  @default(now())

  patient                Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccImmunizationId])
  @@map("patient_immunizations")
}

model PatientDiagnosticReport {
  id                   String    @id @default(uuid())
  patientId            String
  pccReportId          String?
  reportName           String?
  reportType           String?
  reportStatus         String?
  category             String?
  effectiveDateTime    DateTime?
  orderingPractitioner String?
  syncedAt             DateTime  @default(now())

  patient              Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccReportId])
  @@map("patient_diagnostic_reports")
}

model PatientCarePlan {
  id             String    @id @default(uuid())
  patientId      String
  pccCarePlanId  String?
  status         String?
  createdDate    DateTime?
  nextReviewDate DateTime?
  closedDate     DateTime?
  closureReason  String?
  syncedAt       DateTime  @default(now())

  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccCarePlanId])
  @@map("patient_care_plans")
}

model PatientAssessment {
  id                String    @id @default(uuid())
  patientId         String
  pccAssessmentId   String?
  assessmentRefDate DateTime?
  assessmentScore   Float?
  assessmentStatus  String?
  templateId        String?
  syncedAt          DateTime  @default(now())

  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccAssessmentId])
  @@map("patient_assessments")
}

model PatientEpisodeOfCare {
  id           String    @id @default(uuid())
  patientId    String
  pccEpisodeId String?
  name         String?
  type         String?
  status       String?
  startDate    DateTime?
  endDate      DateTime?
  payerName    String?
  payerType    String?
  model        String?
  syncedAt     DateTime  @default(now())

  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, pccEpisodeId])
  @@map("patient_episodes_of_care")
}

model PatientTherapyTrack {
  id                     String    @id @default(uuid())
  patientId              String
  discipline             String?
  onsetDate              DateTime?
  startOfCareDate        DateTime?
  certificationStartDate DateTime?
  certificationEndDate   DateTime?
  medicalDiagnosis       String?
  treatmentDiagnosis     String?
  treatmentFreqPerWeek   String?
  therapyProvider        String?
  syncedAt               DateTime  @default(now())

  patient                Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_therapy_tracks")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTEGRATION HUB — external EMR sync sources + per-resource schedules
// ─────────────────────────────────────────────────────────────────────────────

model IntegrationSource {
  id         String                  @id @default(uuid())
  name       String                  @unique // PCC, MATRIX, MEDREX, SIGMA
  status     String                  @default("disconnected")
  lastSyncAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  configs    IntegrationSyncConfig[]

  @@map("integration_sources")
}

model IntegrationSyncConfig {
  id             String            @id @default(uuid())
  sourceId       String
  resourceName   String
  enabled        Boolean           @default(true)
  frequency      String            @default("DAILY_1AM") // EVERY_4H | EVERY_6H | DAILY_1AM | WEEKLY_MON_1AM
  cronExpression String
  lastSyncAt     DateTime?
  lastCount      Int?
  lastError      String?
  updatedAt      DateTime          @updatedAt
  source         IntegrationSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, resourceName])
  @@map("integration_sync_configs")
}
